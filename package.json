{
  "name": "proteinhunt-playwright-framework",
  "version": "1.0.0",
  "description": "Playwright JavaScript automation framework for ProteinHunt sub system.",
  "private": true,
  "scripts": {
    "test": "node scripts/run-tests-open-extent.js",
    "test:headed": "node scripts/run-tests-open-extent.js --headed",
    "test:smoke": "node scripts/run-tests-open-extent.js --grep @smoke",
    "test:regression": "node scripts/run-tests-open-extent.js --grep @regression",
    "test:sanity": "node scripts/run-tests-open-extent.js --grep @sanity",
    "test:extent": "node scripts/run-tests-open-extent.js",
    "test:report": "npx playwright show-report reports/html-report",
    "show:extent": "cmd /c start \"\" \"reports/extent-report/index.html\"",
    "test:browser": "npx playwright test --project=chromium,firefox,webkit"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.0.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "playwright-html-reporter": "^0.1.11"
  }
}
